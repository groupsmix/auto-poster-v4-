{
  "name": "nexus-v5",
  "version": "5.0.0",
  "description": "NEXUS V5 — Ship or Die Refactor. 3-worker architecture, D1 state machine, niche isolation.",
  "private": true,
  "workspaces": [
    "apps/workers/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "deploy": "turbo run deploy",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "wrangler d1 migrations apply nexus-db",
    "db:generate": "drizzle-kit generate",
    "local:up": "docker-compose up -d",
    "local:down": "docker-compose down",
    "local:logs": "docker-compose logs -f",
    "setup": "bash scripts/setup.sh"
  },
  "devDependencies": {
    "turbo": "^1.11.0",
    "typescript": "^5.3.0",
    "@cloudflare/workers-types": "^4.20231218.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
